rs WHERE id = ?\", (session_id,))\n    \"\"\"\n    async with aiosqlite.connect(DB_NAME) as db:\n        async with db.execute(zapros, params) as cursor:\n            tables = await cursor.fetchall()\n            await db.commit()\n            return tables\n
